# OS
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc
*.pyo
.env
venv/
.venv/

# Deliverables — generated at build time, not committed
deliverables/*.zip

# Large binary assets — store in Google Drive instead
assets/images/*.png
assets/images/*.jpg
assets/images/*.jpeg

# Secrets
*.key
*.pem
secrets.json

.vercel

# Claude Code — per-machine local config (may contain tokens in permission entries)
.claude/settings.local.json
.claude/.credentials*
.claude/worktrees/
# Installed skills — machine-specific symlinks, restore with `npx skills experimental_install`
.claude/skills/
.agents/
# Skills CLI creates one dir per supported agent — none of these are source-controlled
.adal/
.augment/
.bob/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/
skills/

# Next.js build artifacts (in case a build runs at repo root by mistake)
.next/
**/.next/

