{
  "framework": "nextjs",
  "buildCommand": "npm test && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/publish-instagram",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/refresh-instagram-token",
      "schedule": "0 4 * * 0"
    }
  ]
}
