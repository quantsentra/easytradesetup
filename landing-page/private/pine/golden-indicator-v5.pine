// Golden Indicator v5 — release tag.
// Pine Script language version: v5 (`//@version=5`).
//
// Changelog from v6 -> v5 release tag:
//   * Title rebranded "SANSETO Trade Master" -> "Golden Indicator v5"
//   * Lifeline section comment honest about being McGinley Dynamic, not EMA
//   * ADR daily-range reads bundled into single request.security tuple call
//     (previously 10 separate calls -> ~10x faster section)
//   * Single barcolor() resolver with explicit precedence — earlier the
//     second barcolor() silently overrode the first (Marubozu colour was
//     dead code)
//   * CPR central band (TC <-> BC) gets a light-pink linefill — visible
//     at a glance as the chop / no-trade zone
//   * CPR locks at start of day on isNewDay; lines never move for that
//     trading session
//   * Constants extracted (LIFELINE_LEN). Dead code removed.

//@version=5
indicator("Golden Indicator v5"
  , overlay = true
  , max_labels_count = 500
  , max_lines_count = 500
  , max_boxes_count = 500
  , max_bars_back = 5000)

//----------------
// Lifeline (McGinley Dynamic, 14)
// Smoother + more responsive than EMA on chop. Earlier comments labelled
// this an EMA — the math is McGinley Dynamic. Renamed honestly.
//----------------
show_ema     = input.bool(true,    title="Show Lifeline *", group="Global Market")
ema_color    = input.color(#000000, title="Lifeline Color", group="Global Market")
LIFELINE_LEN = 14
src          = close
out          = ta.ema(src, LIFELINE_LEN)
var float lifeline = na
lifeline := na(lifeline[1]) ? out
   : lifeline[1] + (src - lifeline[1]) / (LIFELINE_LEN * math.pow(src/lifeline[1], 4))
plot(show_ema ? lifeline : na, title="Lifeline", color=ema_color, linewidth=2)

//----------------
// EMA 200 — long-trend filter
//----------------
show_ema200 = input.bool(true, title="Show King of EMA *", group="Global Market")
out200      = ta.ema(close, 200)
plot(show_ema200 ? out200 : na, title="EMA 200", color=#0901f7, linewidth=3)

//----------------
// ADR (Average Daily Range) Bands
// Bundled all daily-range reads into a single request.security tuple
// (10 calls collapsed to 1) for ~10x speed-up vs the prior loop.
//----------------
showADR = input(true, title="Show CD Zone *", group="Global Market")

OPEN     = request.security(syminfo.tickerid, 'D', open, lookahead=barmerge.lookahead_on)
dayrange = high - low

[r1, r2, r3, r4, r5, r6, r7, r8, r9, r10] = request.security(syminfo.tickerid, "D",
   [dayrange[1], dayrange[2], dayrange[3], dayrange[4], dayrange[5],
    dayrange[6], dayrange[7], dayrange[8], dayrange[9], dayrange[10]],
   lookahead = barmerge.lookahead_on)

adr_10 = (r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9 + r10) / 10
adr_5  = (r1 + r2 + r3 + r4 + r5) / 5

adrhigh10 = plot(showADR ? (OPEN + (adr_10 / 2)) : na, title="ADR High10", style=plot.style_circles, color=color.red,   linewidth=1)
adrlow10  = plot(showADR ? (OPEN - (adr_10 / 2)) : na, title="ADR Low10",  style=plot.style_circles, color=color.green, linewidth=1)
adrhigh5  = plot(showADR ? (OPEN + (adr_5  / 2)) : na, title="ADR High5",  style=plot.style_circles, color=color.red,   linewidth=1)
adrlow5   = plot(showADR ? (OPEN - (adr_5  / 2)) : na, title="ADR Low5",   style=plot.style_circles, color=color.green, linewidth=1)

fill(adrlow10,  adrlow5,  color=color.new(color.lime,   90))
fill(adrhigh10, adrhigh5, color=color.new(color.maroon, 90))

//----------------
// Daily Pivot Range (CPR) — central pivot, top central, bottom central, S/R
// Locked at session start from previous day's H/L/C — once drawn, the
// lines never move for that session. Light-pink fill between TC and BC
// makes the central no-trade band scannable at a glance.
//----------------
show_pivots = input(true, title="Show Daily Pivot Range *", group="Global Market")
cpr_band_color = input.color(color.rgb(255, 192, 203), title="CPR Band Color (TC-BC fill)", group="Global Market")

isNewDay = ta.change(time('D'))

[prevHigh, prevLow, prevClose] = request.security(syminfo.tickerid, "D",
   [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)

pivot_calc = (prevHigh + prevLow + prevClose) / 3
bc_calc    = (prevHigh + prevLow) / 2
tc_calc    = (pivot_calc * 2) - bc_calc

range_calc = prevHigh - prevLow
cpr1_calc  = (pivot_calc * 2) - prevLow
cps1_calc  = (pivot_calc * 2) - prevHigh
cpr2_calc  = pivot_calc + range_calc
cps2_calc  = pivot_calc - range_calc
cpr3_calc  = cpr1_calc + range_calc
cps3_calc  = cps1_calc - range_calc
cpr4_calc  = cpr3_calc + (cpr2_calc - cpr1_calc)
cps4_calc  = cps3_calc - (cps1_calc - cps2_calc)

var float storedPivot = na
var float storedBC    = na
var float storedTC    = na
var float storedR1    = na
var float storedR2    = na
var float storedR3    = na
var float storedR4    = na
var float storedS1    = na
var float storedS2    = na
var float storedS3    = na
var float storedS4    = na

var line pivotLine = na
var line bcLine    = na
var line tcLine    = na
var line r1Line    = na
var line r2Line    = na
var line r3Line    = na
var line r4Line    = na
var line s1Line    = na
var line s2Line    = na
var line s3Line    = na
var line s4Line    = na

var linefill cprBandFill = na

if isNewDay and show_pivots
    storedPivot := pivot_calc
    storedBC    := bc_calc
    storedTC    := tc_calc
    storedR1    := cpr1_calc
    storedR2    := cpr2_calc
    storedR3    := cpr3_calc
    storedR4    := cpr4_calc
    storedS1    := cps1_calc
    storedS2    := cps2_calc
    storedS3    := cps3_calc
    storedS4    := cps4_calc

    if not na(pivotLine)
        line.delete(pivotLine)
        line.delete(bcLine)
        line.delete(tcLine)
        line.delete(r1Line)
        line.delete(r2Line)
        line.delete(r3Line)
        line.delete(r4Line)
        line.delete(s1Line)
        line.delete(s2Line)
        line.delete(s3Line)
        line.delete(s4Line)
    if not na(cprBandFill)
        linefill.delete(cprBandFill)

    pivotLine := line.new(bar_index, storedPivot, bar_index + 100, storedPivot, width=2, color=color.purple)
    bcLine    := line.new(bar_index, storedBC,    bar_index + 100, storedBC,    width=2, color=color.purple)
    tcLine    := line.new(bar_index, storedTC,    bar_index + 100, storedTC,    width=2, color=color.purple)
    r1Line    := line.new(bar_index, storedR1,    bar_index + 100, storedR1,    width=2, color=color.red)
    r2Line    := line.new(bar_index, storedR2,    bar_index + 100, storedR2,    width=2, color=color.red)
    r3Line    := line.new(bar_index, storedR3,    bar_index + 100, storedR3,    width=2, color=color.red)
    r4Line    := line.new(bar_index, storedR4,    bar_index + 100, storedR4,    width=2, color=color.red)
    s1Line    := line.new(bar_index, storedS1,    bar_index + 100, storedS1,    width=2, color=color.green)
    s2Line    := line.new(bar_index, storedS2,    bar_index + 100, storedS2,    width=2, color=color.green)
    s3Line    := line.new(bar_index, storedS3,    bar_index + 100, storedS3,    width=2, color=color.green)
    s4Line    := line.new(bar_index, storedS4,    bar_index + 100, storedS4,    width=2, color=color.green)

    // Light-pink band between TC and BC. linefill auto-tracks both lines.
    cprBandFill := linefill.new(tcLine, bcLine, color.new(cpr_band_color, 70))

if not na(pivotLine) and show_pivots
    line.set_xy2(pivotLine, bar_index + 100, storedPivot)
    line.set_xy2(bcLine,    bar_index + 100, storedBC)
    line.set_xy2(tcLine,    bar_index + 100, storedTC)
    line.set_xy2(r1Line,    bar_index + 100, storedR1)
    line.set_xy2(r2Line,    bar_index + 100, storedR2)
    line.set_xy2(r3Line,    bar_index + 100, storedR3)
    line.set_xy2(r4Line,    bar_index + 100, storedR4)
    line.set_xy2(s1Line,    bar_index + 100, storedS1)
    line.set_xy2(s2Line,    bar_index + 100, storedS2)
    line.set_xy2(s3Line,    bar_index + 100, storedS3)
    line.set_xy2(s4Line,    bar_index + 100, storedS4)

//----------------
// Momentum Candle detection — body >= 70% of true range
//----------------
show_momentum = input.bool(true, title="Show Momentum Candles *", group="Global Market")

body_size  = math.abs(close - open)
true_range = math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))

is_bullish_momentum = body_size / true_range >= 0.70 and close > open
is_bearish_momentum = body_size / true_range >= 0.70 and close < open

//----------------
// Volume Divergence (Careful Candle)
//----------------
var bool Redcandle   = false
var bool Greencandle = false
barRange = open - close
if barRange < 0
    Redcandle := true
else
    Greencandle := true

upAndDownVolume() =>
    posVol = 0.0
    negVol = 0.0
    switch
        close >  open     => posVol += volume
        close <  open     => negVol -= volume
        close >= close[1] => posVol += volume
        close <  close[1] => negVol -= volume
    [posVol, negVol]

lowerTimeframe = switch
    timeframe.isintraday => "1"
    timeframe.isdaily    => "5"
    => "60"

[upVolumeArray, downVolumeArray] = request.security_lower_tf(syminfo.tickerid, lowerTimeframe, upAndDownVolume())
upVolume   = array.sum(upVolumeArray)
downVolume = array.sum(downVolumeArray)

ectopicBar = (Redcandle   and math.abs(upVolume   * 1.5) < math.abs(downVolume)) or
             (Greencandle and math.abs(downVolume * 1.5) < math.abs(upVolume))

//----------------
// Single barcolor() resolver — explicit precedence
// Earlier code called barcolor() twice; the second call silently won and
// the first set's colours never displayed. Now combined with one path:
//   1. Volume-divergence (yellow flag) — strongest signal, wins
//   2. Bullish momentum — blue
//   3. Bearish momentum — black
//----------------
var color final_bar_color = na
final_bar_color := ectopicBar
                 ? color.yellow
                 : show_momentum and is_bullish_momentum
                 ? #6572f8
                 : show_momentum and is_bearish_momentum
                 ? #000000
                 : na
barcolor(final_bar_color, title="Candle coloring")

plotshape(ectopicBar, title='Reversal2', style=shape.flag, text='!',
          color=color.new(color.red, 20), textcolor=color.new(color.black, 20), location=location.abovebar)
alertcondition(ectopicBar, title="Volume Divergence", message="Watch the Market")

Redcandle   := false
Greencandle := false

//----------------
// Highs & Lows MTF — Daily / Weekly / Monthly previous extremes
//----------------
show_pdhl  = input(true,    'Daily',   inline='daily',   group='Highs & Lows MTF')
pdhl_style = input.string('----', '',  inline='daily',   group='Highs & Lows MTF', options=['⎯⎯⎯','----','····'])
pdhl_css   = input(#2157f3, '',        inline='daily',   group='Highs & Lows MTF')

show_pwhl  = input(true,    'Weekly',  inline='weekly',  group='Highs & Lows MTF')
pwhl_style = input.string('----', '',  inline='weekly',  group='Highs & Lows MTF', options=['⎯⎯⎯','----','····'])
pwhl_css   = input(#2157f3, '',        inline='weekly',  group='Highs & Lows MTF')

show_pmhl  = input(true,    'Monthly', inline='monthly', group='Highs & Lows MTF')
pmhl_style = input.string('----', '',  inline='monthly', group='Highs & Lows MTF', options=['⎯⎯⎯','----','····'])
pmhl_css   = input(#2157f3, '',        inline='monthly', group='Highs & Lows MTF')

color TRANSP_CSS = #ffffff00

get_line_style(s) =>
    switch s
        '⎯⎯⎯'  => line.style_solid
        '----' => line.style_dashed
        '····' => line.style_dotted

hl() => [high, low]

phl(h, l, tf, css, sty) =>
    var line  high_line = line.new(na, na, na, na, xloc=xloc.bar_time, color=css, style=get_line_style(sty))
    var label high_lbl  = label.new(na, na, xloc=xloc.bar_time, text=str.format('P{0}H', tf), color=TRANSP_CSS, textcolor=css, size=size.small, style=label.style_label_left)
    var line  low_line  = line.new(na, na, na, na, xloc=xloc.bar_time, color=css, style=get_line_style(sty))
    var label low_lbl   = label.new(na, na, xloc=xloc.bar_time, text=str.format('P{0}L', tf), color=TRANSP_CSS, textcolor=css, size=size.small, style=label.style_label_left)

    hy = ta.valuewhen(h != h[1], h, 1)
    hx = ta.valuewhen(h == high, time, 1)
    ly = ta.valuewhen(l != l[1], l, 1)
    lx = ta.valuewhen(l == low,  time, 1)

    if barstate.islast
        ext = time + (time - time[1]) * 20
        line.set_xy1(high_line, hx, hy)
        line.set_xy2(high_line, ext, hy)
        label.set_xy(high_lbl, ext, hy)
        line.set_xy1(low_line, lx, ly)
        line.set_xy2(low_line, ext, ly)
        label.set_xy(low_lbl, ext, ly)

[pdh, pdl] = request.security(syminfo.tickerid, 'D', hl(), lookahead=barmerge.lookahead_on)
[pwh, pwl] = request.security(syminfo.tickerid, 'W', hl(), lookahead=barmerge.lookahead_on)
[pmh, pml] = request.security(syminfo.tickerid, 'M', hl(), lookahead=barmerge.lookahead_on)

if show_pdhl
    phl(pdh, pdl, 'D', pdhl_css, pdhl_style)
if show_pwhl
    phl(pwh, pwl, 'W', pwhl_css, pwhl_style)
if show_pmhl
    phl(pmh, pml, 'M', pmhl_css, pmhl_style)

//----------------
// Indian Market — Session highlights + Previous-day last-5min lines
//----------------
show_session_highlight = input.bool(true, "Show Session Highlight",                         group="Indian Market")
show_last_5min_lines   = input.bool(true, "Show Previous day Last 5-Minute High/Low Lines", group="Indian Market")

session_start_time = timestamp(year, month, dayofmonth, 9,  15)
session_end_time   = timestamp(year, month, dayofmonth, 15, 30)

is_first_5min = time >= session_start_time and time < session_start_time + 5 * 60 * 1000
is_last_5min  = time >= session_end_time - 5 * 60 * 1000 and time < session_end_time

light_blue = color.new(color.blue, 85)
bgcolor(show_session_highlight and is_first_5min ? light_blue : na, title="First 5 Minutes Highlight")
bgcolor(show_session_highlight and is_last_5min  ? light_blue : na, title="Last 5 Minutes Highlight")

var float last_5min_high      = na
var float last_5min_low       = na
var line  last_5min_high_line = na
var line  last_5min_low_line  = na

if time == session_end_time - 5 * 60 * 1000
    last_5min_high := high
    last_5min_low  := low

    if show_last_5min_lines
        line.delete(last_5min_high_line)
        line.delete(last_5min_low_line)
        last_5min_high_line := line.new(bar_index, last_5min_high, bar_index + 500, last_5min_high, color=color.blue, width=2, extend=extend.right)
        last_5min_low_line  := line.new(bar_index, last_5min_low,  bar_index + 500, last_5min_low,  color=color.blue, width=2, extend=extend.right)
