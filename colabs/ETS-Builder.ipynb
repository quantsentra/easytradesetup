   "metadata": {},
   "source": [
    "# 🚀 EasyTradeSetup — Automated Pack Builder\n",
    "\n",
    "**What this notebook does, in order:**\n",
    "1. Mounts your Google Drive\n",
    "2. Creates the `EasyTradeSetup/` folder structure in Drive\n",
    "3. Clones the GitHub repo → syncs files into Drive\n",
    "4. Validates all Pine Scripts\n",
    "5. Generates the Strategy PDF guide\n",
    "6. Packages all 3 tier ZIPs (Basic / Pro / Expert)\n",
    "7. Saves everything to Drive → ready for Gumroad upload\n",
    "\n",
    "**Run all cells top to bottom (Runtime → Run all)**"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## STEP 1 — Install Dependencies & Mount Drive"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install fpdf2 -q\n",
    "print(\"✓ fpdf2 installed\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "print(\"✓ Google Drive mounted at /content/drive\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## STEP 2 — Create Drive Folder Structure"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "\n",
    "DRIVE_ROOT = Path('/content/drive/MyDrive')\n",
    "ETS_ROOT   = DRIVE_ROOT / 'EasyTradeSetup'\n",
    "\n",
    "FOLDERS = [\n",
    "    '01_PineScripts',\n",
    "    '02_PDFs',\n",
    "    '03_Deliverables',\n",
    "    '04_Colabs',\n",
    "    '05_LandingPage',\n",
    "    '06_Assets',\n",
    "]\n",
    "\n",
    "print(f\"Creating structure under: {ETS_ROOT}\\n\")\n",
    "for folder in FOLDERS:\n",
    "    path = ETS_ROOT / folder\n",
    "    path.mkdir(parents=True, exist_ok=True)\n",
    "    print(f\"  ✓ {folder}/\")\n",
    "\n",
    "print(\"\\n✓ Drive folder structure ready.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## STEP 3 — Clone GitHub Repo & Sync to Drive"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, shutil\n",
    "\n",
    "REPO_URL  = 'https://github.com/quantsentra/easytradesetup.git'\n",
    "REPO_PATH = Path('/content/easytradesetup')\n",
    "\n",
    "# Clone or pull\n",
    "if REPO_PATH.exists():\n",
    "    result = subprocess.run(['git', '-C', str(REPO_PATH), 'pull'], capture_output=True, text=True)\n",
    "    print(\"Pulled latest from GitHub:\")\n",
    "else:\n",
    "    result = subprocess.run(['git', 'clone', REPO_URL, str(REPO_PATH)], capture_output=True, text=True)\n",
    "    print(\"Cloned repo from GitHub:\")\n",
    "\n",
    "print(result.stdout or result.stderr)\n",
    "\n",
    "# ── Sync Pine Scripts ──────────────────────────────────────────\n",
    "pine_src = REPO_PATH / 'pine-scripts'\n",
    "pine_dst = ETS_ROOT  / '01_PineScripts'\n",
    "\n",
    "copied = 0\n",
    "for f in pine_src.rglob('*.pine'):\n",
    "    shutil.copy2(f, pine_dst / f.name)\n",
    "    print(f\"  ✓ Copied {f.name} → 01_PineScripts/\")\n",
    "    copied += 1\n",
    "\n",
    "# ── Sync Landing Page ──────────────────────────────────────────\n",
    "lp_src = REPO_PATH / 'landing-page' / 'index.html'\n",
    "lp_dst = ETS_ROOT  / '05_LandingPage' / 'index.html'\n",
    "if lp_src.exists():\n",
    "    shutil.copy2(lp_src, lp_dst)\n",
    "    print(f\"  ✓ Copied index.html → 05_LandingPage/\")\n",
    "\n",
    "# ── Sync Colab notebook itself ─────────────────────────────────\n",
    "nb_src = REPO_PATH / 'colabs' / 'ETS-Builder.ipynb'\n",
    "nb_dst = ETS_ROOT  / '04_Colabs' / 'ETS-Builder.ipynb'\n",
    "if nb_src.exists():\n",
    "    shutil.copy2(nb_src, nb_dst)\n",
    "    print(f\"  ✓ Copied ETS-Builder.ipynb → 04_Colabs/\")\n",
    "\n",
    "print(f\"\\n✓ Sync complete. {copied} Pine Script(s) synced.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## STEP 4 — Validate Pine Scripts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "pine_dir = ETS_ROOT / '01_PineScripts'\n",
    "pine_files = list(pine_dir.glob('*.pine'))\n",
    "\n",
    "CHECKS = {\n",
    "    'Pine v5 declaration' : '//@version=5',\n",
    "    'strategy/indicator'  : lambda c: 'strategy(' in c or 'indicator(' in c,\n",
    "    'overlay=true'        : 'overlay=true',\n",
    "    'Supertrend'          : 'ta.supertrend',\n",
    "    'EMA fast/slow'       : lambda c: 'ta.ema' in c,\n",
    "    'RSI filter'          : 'ta.rsi',\n",
    "    'Session filter'      : 'input.session',\n",
    "    'Strategy entry'      : 'strategy.entry',\n",
    "    'Strategy exit'       : 'strategy.exit',\n",
    "    'EOD close'           : 'close_all',\n",
    "}\n",
    "\n",
    "all_passed = True\n",
    "for pine_file in pine_files:\n",
    "    content = pine_file.read_text(encoding='utf-8')\n",
    "    print(f\"\\n📄 {pine_file.name}\")\n",
    "    print(  \"─\" * 40)\n",
    "    for label, check in CHECKS.items():\n",
    "        ok = check(content) if callable(check) else (check in content)\n",
    "        status = '✓' if ok else '✗  MISSING'\n",
    "        if not ok:\n",
    "            all_passed = False\n",
    "        print(f\"  {status}  {label}\")\n",
    "\n",
    "print()\n",
    "if all_passed:\n",
    "    print(\"✓ All checks passed. Scripts are valid.\")\n",
    "else:\n",
    "    print(\"⚠ Some checks failed. Review before shipping.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## STEP 5 — Generate Strategy PDF"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from fpdf import FPDF\n",
    "\n",
    "# ── Colour palette ─────────────────────────────────────────────\n",
    "C_BG      = (13,  17,  23)\n",
    "C_SURFACE = (22,  27,  34)\n",
    "C_BLUE    = (88,  166, 255)\n",
    "C_GREEN   = (0,   200, 83)\n",
    "C_RED     = (244, 67,  54)\n",
    "C_TEXT    = (230, 237, 243)\n",
    "C_MUTED   = (139, 148, 158)\n",
    "C_ORANGE  = (255, 152, 0)\n",
    "\n",
    "\n",
    "class ETS_PDF(FPDF):\n",
    "\n",
    "    def header(self):\n",
    "        self.set_fill_color(*C_BG)\n",
    "        self.rect(0, 0, 210, 15, 'F')\n",
    "        self.set_font('Helvetica', '', 8)\n",
    "        self.set_text_color(*C_MUTED)\n",
    "        self.set_y(5)\n",
    "        self.cell(0, 6, 'EasyTradeSetup  |  easytradesetup.com  |  Nifty & BankNifty Intraday System', align='C')\n",
    "\n",
    "    def footer(self):\n",
    "        self.set_y(-12)\n",
    "        self.set_fill_color(*C_BG)\n",
    "        self.rect(0, self.get_y() - 2, 210, 15, 'F')\n",
    "        self.set_font('Helvetica', '', 8)\n",
    "        self.set_text_color(*C_MUTED)\n",
    "        self.cell(0, 8,\n",
    "            f'Page {self.page_no()}  |  Trading involves risk. Past results do not guarantee future performance. Not SEBI-registered advice.',\n",
    "            align='C')\n",
    "\n",
    "    def bg_fill(self):\n",
    "        self.set_fill_color(*C_BG)\n",
    "        self.rect(0, 0, 210, 297, 'F')\n",
    "\n",
    "    def h1(self, text, color=None):\n",
    "        self.set_font('Helvetica', 'B', 22)\n",
    "        self.set_text_color(*(color or C_BLUE))\n",
    "        self.multi_cell(0, 10, text)\n",
    "        self.ln(2)\n",
    "\n",
    "    def h2(self, text):\n",
    "        self.set_font('Helvetica', 'B', 14)\n",
    "        self.set_text_color(*C_BLUE)\n",
    "        self.ln(4)\n",
    "        self.multi_cell(0, 8, text)\n",
    "        self.set_draw_color(*C_BLUE)\n",
    "        self.set_line_width(0.3)\n",
    "        x = self.get_x()\n",
    "        y = self.get_y()\n",
    "        self.line(10, y, 200, y)\n",
    "        self.ln(4)\n",
    "\n",
    "    def h3(self, text):\n",
    "        self.set_font('Helvetica', 'B', 11)\n",
    "        self.set_text_color(*C_TEXT)\n",
    "        self.ln(3)\n",
    "        self.multi_cell(0, 7, text)\n",
    "        self.ln(1)\n",
    "\n",
    "    def body(self, text):\n",
    "        self.set_font('Helvetica', '', 10)\n",
    "        self.set_text_color(*C_MUTED)\n",
    "        self.multi_cell(0, 6, text)\n",
    "        self.ln(2)\n",
    "\n",
    "    def bullet(self, text, color=None):\n",
    "        self.set_font('Helvetica', '', 10)\n",
    "        self.set_text_color(*(color or C_TEXT))\n",
    "        self.set_x(14)\n",
    "        self.multi_cell(0, 6, f'•  {text}')\n",
    "\n",
    "    def check_row(self, label, value, ok=True):\n",
    "        col = C_GREEN if ok else C_RED\n",
    "        mark = 'YES' if ok else 'NO'\n",
    "        self.set_fill_color(*C_SURFACE)\n",
    "        self.set_font('Helvetica', '', 10)\n",
    "        self.set_text_color(*C_TEXT)\n",
    "        self.set_x(10)\n",
    "        self.cell(100, 8, label, fill=True)\n",
    "        self.set_text_color(*col)\n",
    "        self.cell(20, 8, mark, fill=True)\n",
    "        self.set_text_color(*C_MUTED)\n",
    "        self.cell(0, 8, value, fill=True)\n",
    "        self.ln()\n",
    "\n",
    "    def rule_box(self, title, lines, title_color=None):\n",
    "        self.set_fill_color(*C_SURFACE)\n",
    "        self.set_draw_color(*(title_color or C_BLUE))\n",
    "        self.set_line_width(0.5)\n",
    "        start_y = self.get_y()\n",
    "        self.set_font('Helvetica', 'B', 10)\n",
    "        self.set_text_color(*(title_color or C_BLUE))\n",
    "        self.set_x(10)\n",
    "        self.cell(190, 8, f'  {title}', fill=True)\n",
    "        self.ln()\n",
    "        for line in lines:\n",
    "            self.set_font('Helvetica', '', 10)\n",
    "            self.set_text_color(*C_TEXT)\n",
    "            self.set_x(14)\n",
    "            self.multi_cell(186, 6, line, fill=True)\n",
    "        self.ln(2)\n",
    "\n",
    "\n",
    "# ── Build PDF ──────────────────────────────────────────────────\n",
    "pdf = ETS_PDF()\n",
    "pdf.set_auto_page_break(auto=True, margin=15)\n",
    "\n",
    "\n",
    "# ── COVER PAGE ────────────────────────────────────────────────\n",
    "pdf.add_page()\n",
    "pdf.bg_fill()\n",
    "\n",
    "pdf.set_y(50)\n",
    "pdf.set_font('Helvetica', 'B', 9)\n",
    "pdf.set_text_color(*C_MUTED)\n",
    "pdf.cell(0, 8, 'NIFTY & BANKNIFTY  ·  INTRADAY  ·  TRADINGVIEW', align='C')\n",
    "pdf.ln(10)\n",
    "\n",
    "pdf.set_font('Helvetica', 'B', 36)\n",
    "pdf.set_text_color(*C_BLUE)\n",
    "pdf.multi_cell(0, 14, 'EasyTradeSetup', align='C')\n",
    "\n",
    "pdf.set_font('Helvetica', '', 18)\n",
    "pdf.set_text_color(*C_TEXT)\n",
    "pdf.multi_cell(0, 10, 'Intraday Momentum Pack', align='C')\n",
    "pdf.ln(6)\n",
    "\n",
    "pdf.set_draw_color(*C_BLUE)\n",
    "pdf.set_line_width(0.4)\n",
    "pdf.line(50, pdf.get_y(), 160, pdf.get_y())\n",
    "pdf.ln(10)\n",
    "\n",
    "pdf.set_font('Helvetica', '', 12)\n",
    "pdf.set_text_color(*C_MUTED)\n",
    "for line in [\n",
    "    'EMA 9/21  +  Supertrend (10,3)  +  RSI Filter',\n",
    "    'Clear BUY/SELL Signals  ·  Automated SL & TP',\n",
    "    'Works on Free TradingView Account',\n",
    "]:\n",
    "    pdf.multi_cell(0, 8, line, align='C')\n",
    "\n",
    "pdf.set_y(220)\n",
    "pdf.set_font('Helvetica', 'B', 10)\n",
    "pdf.set_text_color(*C_BLUE)\n",
    "pdf.cell(0, 8, 'Version 1.0  ·  easytradesetup.com', align='C')\n",
    "\n",
    "\n",
    "# ── PAGE 2: DISCLAIMER + WHAT YOU NEED ───────────────────────\n",
    "pdf.add_page()\n",
    "pdf.bg_fill()\n",
    "pdf.set_y(20)\n",
    "\n",
    "pdf.h2('Important Disclaimer')\n",
    "pdf.body(\n",
    "    'This document is for educational purposes only. The strategies and Pine Script code '\n",
    "    'provided are tools to assist your own trading analysis — they are not financial advice, '\n",
    "    'investment recommendations, or SEBI-registered guidance.\\n\\n'\n",
    "    'Trading in F&O instruments (Nifty, BankNifty) involves significant financial risk. '\n",
    "    'You can lose more than your invested capital. Past performance of any strategy is '\n",
    "    'not indicative of future results. Always use proper risk management and trade only '\n",
    "    'with capital you can afford to lose.'\n",
    ")\n",
    "\n",
    "pdf.h2('What You Need Before Starting')\n",
    "pdf.h3('1. TradingView Account')\n",
    "pdf.bullet('Go to tradingview.com and create a free account')\n",
    "pdf.bullet('Free plan works perfectly for this strategy')\n",
    "pdf.bullet('Chart the NIFTY or BANKNIFTY symbol (NSE exchange)')\n",
    "pdf.ln(3)\n",
    "\n",
    "pdf.h3('2. Recommended Chart Settings')\n",
    "pdf.bullet('Timeframe: 15-minute (recommended for beginners)')\n",
    "pdf.bullet('Chart type: Candlestick')\n",
    "pdf.bullet('Theme: Dark (easier to read signals)')\n",
    "pdf.bullet('Symbol: NSE:NIFTYBANK or NSE:NIFTY')\n",
    "pdf.ln(3)\n",
    "\n",
    "pdf.h3('3. Installing the Pine Script')\n",
    "pdf.bullet('Open Pine Script Editor (bottom panel on TradingView)')\n",
    "pdf.bullet('Delete existing code and paste the full ETS-Intraday-v1.0.pine content')\n",
    "pdf.bullet('Click Save, then click Add to Chart')\n",
    "pdf.bullet('You will see EMA lines, Supertrend, and BUY/SELL labels appear')\n",
    "\n",
    "\n",
    "# ── PAGE 3: UNDERSTANDING THE INDICATORS ─────────────────────\n",
    "pdf.add_page()\n",
    "pdf.bg_fill()\n",
    "pdf.set_y(20)\n",
    "\n",
    "pdf.h2('Understanding the 3 Indicators')\n",
    "pdf.body('The ETS Momentum Setup uses three indicators in combination. '\n",
    "         'All three must agree before a trade signal is generated. '\n",
    "         'This is called confluence — it reduces false signals significantly.')\n",
    "\n",
    "pdf.rule_box('Indicator 1 — EMA 9 / 21 (Exponential Moving Average)',\n",
    "    [\n",
    "        'Setting: Fast EMA = 9, Slow EMA = 21',\n",
    "        'What it does: Measures the direction of the current trend.',\n",
    "        'How to read: When EMA 9 (blue line) is ABOVE EMA 21 (orange line) = bullish trend.',\n",
    "        '             When EMA 9 is BELOW EMA 21 = bearish trend.',\n",
    "        'Why we use it: Prevents trading against the dominant intraday trend.',\n",
    "    ], title_color=C_BLUE)\n",
    "\n",
    "pdf.rule_box('Indicator 2 — Supertrend (ATR 10, Multiplier 3.0)',\n",
    "    [\n",
    "        'Setting: ATR Period = 10, Multiplier = 3.0',\n",
    "        'What it does: Identifies precise entry timing based on volatility.',\n",
    "        'How to read: Green line below price = buy zone. Red line above price = sell zone.',\n",
    "        '             When the line FLIPS colour = potential trade entry.',\n",
    "        'Why we use it: Gives a specific, objective entry point — removes guesswork.',\n",
    "    ], title_color=C_GREEN)\n",
    "\n",
    "pdf.rule_box('Indicator 3 — RSI Filter (14 period)',\n",
    "    [\n",
    "        'Setting: Period = 14',\n",
    "        'What it does: Measures momentum strength (scale of 0 to 100).',\n",
    "        'How we use it: LONG only if RSI is between 45 and 70 (momentum building).',\n",
    "        '               SHORT only if RSI is between 30 and 55 (momentum dropping).',\n",
    "        'Why we use it: Filters out weak moves and exhausted trends before entry.',\n",
    "    ], title_color=C_ORANGE)\n",
    "\n",
    "\n",
    "# ── PAGE 4: LONG TRADE RULES ──────────────────────────────────\n",
    "pdf.add_page()\n",
    "pdf.bg_fill()\n",
    "pdf.set_y(20)\n",
    "\n",
    "pdf.h2('Long Trade — Step by Step Rules')\n",
    "pdf.body('A long trade means you are buying, expecting the price to go up. '\n",
    "         'In Nifty/BankNifty F&O this means buying a Call option or a futures contract.')\n",
    "\n",
    "pdf.rule_box('Entry Checklist — ALL 5 must be true',\n",
    "    [\n",
    "        '1. EMA 9 is ABOVE EMA 21 (blue line above orange line)',\n",
    "        '2. Supertrend line has just turned GREEN (flipped from red to green)',\n",
    "        '3. RSI value is between 45 and 70',\n",
    "        '4. Current time is between 9:20 AM and 3:00 PM IST',\n",
    "        '5. You are NOT already in a trade',\n",
    "        '',\n",
    "        '→ Enter at the CLOSE of the candle where the BUY label appears.',\n",
    "    ], title_color=C_GREEN)\n",
    "\n",
    "pdf.rule_box('Stop Loss',\n",
    "    [\n",
    "        'Set your stop loss at 0.5% below your entry price.',\n",
    "        'Example: Entry at 44,000 → Stop Loss at 43,780',\n",
    "        'The script calculates this automatically in the strategy tester.',\n",
    "    ], title_color=C_RED)\n",
    "\n",
    "pdf.rule_box('Target',\n",
    "    [\n",
    "        'Target = 1.5x your stop loss distance (1:1.5 risk-reward).',\n",
    "        'Example: Entry 44,000 | SL 43,780 (220 pts) | Target 44,330 (330 pts)',\n",
    "        'The script auto-calculates and places this exit.',\n",
    "    ], title_color=C_GREEN)\n",
    "\n",
    "pdf.rule_box('Early Exit Rules',\n",
    "    [\n",
    "        '• Supertrend flips back to RED before target → exit immediately',\n",
    "        '• Time reaches 3:00 PM IST → exit regardless of position',\n",
    "        '• Never hold Nifty/BankNifty F&O positions overnight',\n",
    "    ], title_color=C_ORANGE)\n",
    "\n",
    "\n",
    "# ── PAGE 5: SHORT TRADE RULES ─────────────────────────────────\n",
    "pdf.add_page()\n",
    "pdf.bg_fill()\n",
    "pdf.set_y(20)\n",
    "\n",
    "pdf.h2('Short Trade — Step by Step Rules')\n",
    "pdf.body('A short trade means you are selling, expecting the price to go down. '\n",
    "         'In F&O this means buying a Put option or selling a futures contract.')\n",
    "\n",
    "pdf.rule_box('Entry Checklist — ALL 5 must be true',\n",
    "    [\n",
    "        '1. EMA 9 is BELOW EMA 21 (blue line below orange line)',\n",
    "        '2. Supertrend line has just turned RED (flipped from green to red)',\n",
    "        '3. RSI value is between 30 and 55',\n",
    "        '4. Current time is between 9:20 AM and 3:00 PM IST',\n",
    "        '5. You are NOT already in a trade',\n",
    "        '',\n",
    "        '→ Enter at the CLOSE of the candle where the SELL label appears.',\n",
    "    ], title_color=C_RED)\n",
    "\n",
    "pdf.rule_box('Stop Loss',\n",
    "    [\n",
    "        'Set your stop loss at 0.5% above your entry price.',\n",
    "        'Example: Entry at 44,000 → Stop Loss at 44,220',\n",
    "    ], title_color=C_RED)\n",
    "\n",
    "pdf.rule_box('Target',\n",
    "    [\n",
    "        'Target = 1.5x your stop loss distance (1:1.5 risk-reward).',\n",
    "        'Example: Entry 44,000 | SL 44,220 (220 pts) | Target 43,670 (330 pts)',\n",
    "    ], title_color=C_GREEN)\n",
    "\n",
    "pdf.rule_box('Early Exit Rules',\n",
    "    [\n",
    "        '• Supertrend flips back to GREEN before target → exit immediately',\n",
    "        '• Time reaches 3:00 PM IST → exit regardless of position',\n",
    "    ], title_color=C_ORANGE)\n",
    "\n",
    "\n",
    "# ── PAGE 6: RISK MANAGEMENT ───────────────────────────────────\n",
    "pdf.add_page()\n",
    "pdf.bg_fill()\n",
    "pdf.set_y(20)\n",
    "\n",
    "pdf.h2('Risk Management Rules')\n",
    "pdf.body('These rules are non-negotiable. Most traders lose money not because their '\n",
    "         'strategy is wrong, but because they break risk rules when emotions take over.')\n",
    "\n",
