// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © EasyTradeSetup
//
// Golden Indicator v5 — release tag.
// Pine Script language version: v5 (`//@version=5`).
//
// Patch notes:
//   * Header + indicator() title rebranded to EasyTradeSetup / Golden Indicator v5
//   * Lifeline section comment honest about being McGinley Dynamic, not EMA
//   * ADR daily-range reads bundled into a single request.security() tuple
//     call via helper function (Pine v5 forbids multi-line tuple literals
//     inside request.security)
//   * Single barcolor() resolver — momentum > volume-divergence > marubozu
//     precedence. Earlier code called barcolor() twice and the second call
//     silently won, leaving the first set's colours dead.
//   * CPR rendering switched from per-bar plot() to per-day-locked
//     line.new() so the central band never moves once drawn for that
//     session. linefill() between TC and BC marks the no-trade chop zone
//     (configurable color via input).
//   * Yellow Careful Candle (volume-divergence) brought in from v7. Multi-
//     timeframe up/down volume read via request.security_lower_tf; flag +
//     alertcondition fire when volume context contradicts the candle body.
//   * Bullish / bearish candle colours softened — pure blue/black were
//     too harsh against the chart backdrop.
//   * Smart Money Concept block removed entirely (Structure / Order Blocks
//     / FVG / EQH-EQL / Premium-Discount-Equilibrium / Golden Zone).
//     Was too noisy and overlapped the Grandpa supply/demand layer.
//   * Sonarlab Order Block section omitted — upstream paste was truncated;
//     append-ready in the file footer when the full source is available.

//@version=5
indicator("Golden Indicator v5"
  , overlay = true
  , max_labels_count = 500
  , max_lines_count = 500
  , max_boxes_count = 500
  , max_bars_back = 5000)

//----------------
// Setup Profile — one-click tiers
// Pine cannot detect device or hide inputs dynamically, but a single
// dropdown can drive every show_X flag downstream. Selecting a tier
// turns its bundle on; "Custom" hands control back to the per-feature
// toggles the rest of the script defines.
//----------------

setup_profile = input.string("Pro", title="🎯 Setup Profile",
   options=["Beginner", "Pro", "Expert", "Custom"],
   group="👋 Start Here",
   tooltip="Pick this once. The settings groups below are optional — only used if you want to fine-tune.\n\nBeginner — Lifeline + Trap Alerts (Yellow) + Buy/Sell Signals + blue/black candles\nPro     — Beginner + Power Move Zones (CD) + King EMA + Big Buyer/Seller Zones + Sessions + MTF\nExpert  — Pro + Daily Magnetic Zone (CPR)\nCustom  — switch each feature on/off individually in the groups below")

is_beginner_or_up = setup_profile == "Beginner" or setup_profile == "Pro" or setup_profile == "Expert"
is_pro_or_up      = setup_profile == "Pro"      or setup_profile == "Expert"
is_expert_or_up   = setup_profile == "Expert"
is_custom         = setup_profile == "Custom"

//----------------
// Display — label size (mobile-friendly when set Large/Huge)
// Pine has no device detection. Pick a size that reads on your screen:
//   Small/Normal — desktop
//   Large/Huge   — mobile / shared screenshots
//----------------

label_size_in = input.string("Normal", title="Label Size (raise on mobile)",
   options=["Small", "Normal", "Large", "Huge"],
   group="👋 Start Here")

auto_theme_colors = input.bool(true, title="Auto-adapt to chart theme (light/dark)",
   group="👋 Start Here",
   tooltip="When ON, labels + Lifeline auto-pick black on light theme and white on dark theme. Turn OFF to use the manual colour pickers below.")

label_color_manual = input.color(color.black, title="Label Text Color (manual)",
   group="🛠 Manual Overrides",
   tooltip="Used only when 'Auto-adapt to chart theme' is OFF.")

label_size = label_size_in == "Small" ? size.small : label_size_in == "Large" ? size.large : label_size_in == "Huge" ? size.huge : size.normal

// Theme-resolved colour. chart.fg_color returns black on light theme,
// white on dark theme — so the same script reads cleanly on both.
label_color = auto_theme_colors ? chart.fg_color : label_color_manual

show_legend = input.bool(true, title="Show Candle Color Legend",
   group="👋 Start Here",
   tooltip="Fixed legend in the bottom-right explaining what blue / black / yellow candles mean.")

//----------------
// Lifeline — McGinley Dynamic (length 14)
// Smoother + more responsive than EMA on chop. Earlier comments labelled
// this an EMA — the math is McGinley Dynamic. Renamed honestly.
//----------------

show_ema         = input.bool(true,    title="Show Lifeline (smart trend) *", group="🎨 Candles & Trends")
ema_color_manual = input.color(#000000, title="Lifeline Color (manual)",       group="🛠 Manual Overrides", tooltip="Used only when 'Auto-adapt to chart theme' is OFF.")
show_ema_eff     = is_custom ? show_ema : is_beginner_or_up
// Theme-aware Lifeline colour. Dark theme → white line, light theme → black.
ema_color        = auto_theme_colors ? chart.fg_color : ema_color_manual
LIFELINE_LEN = 14
src = close
out = ta.ema(src, LIFELINE_LEN)
var float lifeline = na
lifeline := na(lifeline[1]) ? out
   : lifeline[1] + (src - lifeline[1]) / (LIFELINE_LEN * math.pow(src/lifeline[1], 4))
plot(show_ema_eff ? lifeline : na, title="Lifeline", color=ema_color, linewidth=2)

//----------------
// EMA 200 — long-trend filter
//----------------

show_ema200 = input.bool(false, title="Show King EMA (200-period) *", group="🎨 Candles & Trends")
show_ema200_eff = is_custom ? show_ema200 : is_pro_or_up
out200 = ta.ema(close, 200)
// #3D5AFA — softer electric blue. Pure #0901f7 was 100% saturation =
// reads as alarm rather than reference layer.
plot(show_ema200_eff ? out200 : na, title="King EMA (200)", color=#3D5AFA, linewidth=3)

//----------------
// Power Move Zones (a.k.a. CD Zone — Average Daily Range bands)
// Locked at session start with line.new() so each day's zones extend
// across the session instead of dotted-circle marks. Top zone is where
// price tends to exhaust upside (huge selling expected); bottom zone
// is where downside exhausts (huge buying expected).
//----------------

showADR = input(true, title="Show Power Move Zones (CD) *", group="📊 Price Zones")
show_adr_eff = is_custom ? showADR : is_pro_or_up

OPEN     = request.security(syminfo.tickerid, 'D', open, lookahead=barmerge.lookahead_on)
dayrange = high - low

adrTuple() => [dayrange[1], dayrange[2], dayrange[3], dayrange[4], dayrange[5], dayrange[6], dayrange[7], dayrange[8], dayrange[9], dayrange[10]]
[r1, r2, r3, r4, r5, r6, r7, r8, r9, r10] = request.security(syminfo.tickerid, "D", adrTuple(), lookahead=barmerge.lookahead_on)

adr_10 = (r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9 + r10) / 10
adr_5  = (r1 + r2 + r3 + r4 + r5) / 5

adr_isNewDay = ta.change(time('D'))

var float storedAdrHigh10 = na
var float storedAdrLow10  = na
var float storedAdrHigh5  = na
var float storedAdrLow5   = na

var line  adrHigh10Line = na
var line  adrLow10Line  = na
var line  adrHigh5Line  = na
var line  adrLow5Line   = na

var linefill adrTopFill = na
var linefill adrBotFill = na

var label adrTopLbl = na
var label adrBotLbl = na

if adr_isNewDay and show_adr_eff
    storedAdrHigh10 := OPEN + (adr_10 / 2)
    storedAdrLow10  := OPEN - (adr_10 / 2)
    storedAdrHigh5  := OPEN + (adr_5  / 2)
    storedAdrLow5   := OPEN - (adr_5  / 2)

    if not na(adrHigh10Line)
        line.delete(adrHigh10Line)
        line.delete(adrLow10Line)
        line.delete(adrHigh5Line)
        line.delete(adrLow5Line)
    if not na(adrTopFill)
        linefill.delete(adrTopFill)
        linefill.delete(adrBotFill)
    if not na(adrTopLbl)
        label.delete(adrTopLbl)
        label.delete(adrBotLbl)

    adrHigh10Line := line.new(bar_index, storedAdrHigh10, bar_index + 100, storedAdrHigh10, color=color.red,   width=1, style=line.style_dotted)
    adrLow10Line  := line.new(bar_index, storedAdrLow10,  bar_index + 100, storedAdrLow10,  color=color.green, width=1, style=line.style_dotted)
    adrHigh5Line  := line.new(bar_index, storedAdrHigh5,  bar_index + 100, storedAdrHigh5,  color=color.red,   width=1, style=line.style_dotted)
    adrLow5Line   := line.new(bar_index, storedAdrLow5,   bar_index + 100, storedAdrLow5,   color=color.green, width=1, style=line.style_dotted)

    // Cleaner red/green hue family for the Power Move bands. Maroon read
    // as "old blood" + lime was too saturated — both pulled the eye away
    // from price action. Reds and greens at 90% transparency keep the
    // bands as quiet context.
    adrTopFill := linefill.new(adrHigh10Line, adrHigh5Line, color.new(color.red,   90))
    adrBotFill := linefill.new(adrLow10Line,  adrLow5Line,  color.new(color.green, 90))

    // CD Zone labels intentionally use size.small — they're context, not
    // primary signals. Magnetic Zone keeps the user-controlled label_size
    // so traders can scale that one for mobile.
    adrTopLbl := label.new(bar_index + 50, math.avg(storedAdrHigh10, storedAdrHigh5), "Huge Selling Expected for the Day",
       xloc=xloc.bar_index, color=#ffffff00, textcolor=label_color, style=label.style_label_center, size=size.small)
    adrBotLbl := label.new(bar_index + 50, math.avg(storedAdrLow10,  storedAdrLow5),  "Huge Buying Expected for the Day",
       xloc=xloc.bar_index, color=#ffffff00, textcolor=label_color, style=label.style_label_center, size=size.small)

if not na(adrHigh10Line) and show_adr_eff
    line.set_xy2(adrHigh10Line, bar_index + 100, storedAdrHigh10)
    line.set_xy2(adrLow10Line,  bar_index + 100, storedAdrLow10)
    line.set_xy2(adrHigh5Line,  bar_index + 100, storedAdrHigh5)
    line.set_xy2(adrLow5Line,   bar_index + 100, storedAdrLow5)
    if not na(adrTopLbl)
        label.set_xy(adrTopLbl, bar_index + 50, math.avg(storedAdrHigh10, storedAdrHigh5))
        label.set_xy(adrBotLbl, bar_index + 50, math.avg(storedAdrLow10,  storedAdrLow5))

//----------------
// Central Pivot Range (CPR) — locked at session start, light-pink TC↔BC band
// Switched from per-bar plot() to per-day line.new() so the lines never
// move once drawn for the current session. linefill() between TC and BC
// marks the central no-trade band.
//----------------

show_pivots    = input(true, title="Show Daily Magnetic Zone (CPR) *", group="📊 Price Zones")
cpr_band_color = input.color(color.rgb(255, 192, 203), title="Magnetic Zone Fill Color", group="📊 Price Zones")
show_pivots_eff = is_custom ? show_pivots : is_expert_or_up

isNewDay = ta.change(time('D'))

prevHLC() => [high[1], low[1], close[1]]
[prevHigh, prevLow, prevClose] = request.security(syminfo.tickerid, "D", prevHLC(), lookahead=barmerge.lookahead_on)

pivot_calc = (prevHigh + prevLow + prevClose) / 3
bc_calc    = (prevHigh + prevLow) / 2
tc_calc    = (pivot_calc * 2) - bc_calc

range_calc = prevHigh - prevLow
cpr1_calc  = (pivot_calc * 2) - prevLow
cps1_calc  = (pivot_calc * 2) - prevHigh
cpr2_calc  = pivot_calc + range_calc
cps2_calc  = pivot_calc - range_calc
cpr3_calc  = cpr1_calc + range_calc
cps3_calc  = cps1_calc - range_calc
cpr4_calc  = cpr3_calc + (cpr2_calc - cpr1_calc)
cps4_calc  = cps3_calc - (cps1_calc - cps2_calc)

var float storedPivot = na
var float storedBC    = na
var float storedTC    = na
var float storedR1    = na
var float storedR2    = na
var float storedR3    = na
var float storedR4    = na
var float storedS1    = na
var float storedS2    = na
var float storedS3    = na
var float storedS4    = na

var line pivotLine = na
var line bcLine    = na
var line tcLine    = na
var line r1Line    = na
var line r2Line    = na
var line r3Line    = na
var line r4Line    = na
var line s1Line    = na
var line s2Line    = na
var line s3Line    = na
var line s4Line    = na

var linefill cprBandFill = na
// "Magnetic Zone" tag — TC, Pivot, BC together form the central magnetic
// zone where price tends to oscillate. Centered text label refreshed at
// session start so traders see the tag without hovering any line.
var label cprMagneticLbl = na

// Price-value tags pinned to the right tip of each pivot line. Lets
// traders read the exact target without hovering — same number TV shows
// on the price axis, but inline so it survives axis-clutter.
var label pivotPriceLbl = na
var label bcPriceLbl    = na
var label tcPriceLbl    = na
var label r1PriceLbl    = na
var label r2PriceLbl    = na
var label r3PriceLbl    = na
var label r4PriceLbl    = na
var label s1PriceLbl    = na
var label s2PriceLbl    = na
var label s3PriceLbl    = na
var label s4PriceLbl    = na

// Tiny helper to format a price using the symbol's mintick precision.
fmtPrice(p) => str.tostring(p, format.mintick)

if isNewDay and show_pivots_eff
    storedPivot := pivot_calc
    storedBC    := bc_calc
    storedTC    := tc_calc
    storedR1    := cpr1_calc
    storedR2    := cpr2_calc
    storedR3    := cpr3_calc
    storedR4    := cpr4_calc
    storedS1    := cps1_calc
    storedS2    := cps2_calc
    storedS3    := cps3_calc
    storedS4    := cps4_calc

    if not na(pivotLine)
        line.delete(pivotLine)
        line.delete(bcLine)
        line.delete(tcLine)
        line.delete(r1Line)
        line.delete(r2Line)
        line.delete(r3Line)
        line.delete(r4Line)
        line.delete(s1Line)
        line.delete(s2Line)
        line.delete(s3Line)
        line.delete(s4Line)
    if not na(cprBandFill)
        linefill.delete(cprBandFill)
    if not na(cprMagneticLbl)
        label.delete(cprMagneticLbl)
    if not na(pivotPriceLbl)
        label.delete(pivotPriceLbl)
        label.delete(bcPriceLbl)
        label.delete(tcPriceLbl)
        label.delete(r1PriceLbl)
        label.delete(r2PriceLbl)
        label.delete(r3PriceLbl)
        label.delete(r4PriceLbl)
        label.delete(s1PriceLbl)
        label.delete(s2PriceLbl)
        label.delete(s3PriceLbl)
        label.delete(s4PriceLbl)

    pivotLine := line.new(bar_index, storedPivot, bar_index + 100, storedPivot, width=2, color=color.purple)
    bcLine    := line.new(bar_index, storedBC,    bar_index + 100, storedBC,    width=2, color=color.purple)
    tcLine    := line.new(bar_index, storedTC,    bar_index + 100, storedTC,    width=2, color=color.purple)
    r1Line    := line.new(bar_index, storedR1,    bar_index + 100, storedR1,    width=2, color=color.red)
    r2Line    := line.new(bar_index, storedR2,    bar_index + 100, storedR2,    width=2, color=color.red)
    r3Line    := line.new(bar_index, storedR3,    bar_index + 100, storedR3,    width=2, color=color.red)
    r4Line    := line.new(bar_index, storedR4,    bar_index + 100, storedR4,    width=2, color=color.red)
    s1Line    := line.new(bar_index, storedS1,    bar_index + 100, storedS1,    width=2, color=color.green)
    s2Line    := line.new(bar_index, storedS2,    bar_index + 100, storedS2,    width=2, color=color.green)
    s3Line    := line.new(bar_index, storedS3,    bar_index + 100, storedS3,    width=2, color=color.green)
    s4Line    := line.new(bar_index, storedS4,    bar_index + 100, storedS4,    width=2, color=color.green)

    cprBandFill := linefill.new(tcLine, bcLine, color.new(cpr_band_color, 70))

    // Magnetic-zone tag — sits between TC and BC at the centre of the
    // session's bar window. Transparent background so the band shows
    // through; muted purple text matches the pivot lines.
    cprMagneticLbl := label.new(bar_index + 50, math.avg(storedTC, storedBC), "Magnetic Zone",
       xloc=xloc.bar_index,
       color=#ffffff00,
       textcolor=label_color,
       style=label.style_label_center,
       size=label_size)

    // Price-tag style: triangle points at the line, text reads to the
    // right. Tiny size so 11 tags don't crowd the right edge.
    pivotPriceLbl := label.new(bar_index + 100, storedPivot, fmtPrice(storedPivot), xloc=xloc.bar_index, color=#ffffff00, textcolor=color.purple, style=label.style_label_left, size=size.small)
    bcPriceLbl    := label.new(bar_index + 100, storedBC,    fmtPrice(storedBC),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.purple, style=label.style_label_left, size=size.small)
    tcPriceLbl    := label.new(bar_index + 100, storedTC,    fmtPrice(storedTC),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.purple, style=label.style_label_left, size=size.small)
    r1PriceLbl    := label.new(bar_index + 100, storedR1,    fmtPrice(storedR1),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.red,    style=label.style_label_left, size=size.small)
    r2PriceLbl    := label.new(bar_index + 100, storedR2,    fmtPrice(storedR2),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.red,    style=label.style_label_left, size=size.small)
    r3PriceLbl    := label.new(bar_index + 100, storedR3,    fmtPrice(storedR3),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.red,    style=label.style_label_left, size=size.small)
    r4PriceLbl    := label.new(bar_index + 100, storedR4,    fmtPrice(storedR4),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.red,    style=label.style_label_left, size=size.small)
    s1PriceLbl    := label.new(bar_index + 100, storedS1,    fmtPrice(storedS1),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.green,  style=label.style_label_left, size=size.small)
    s2PriceLbl    := label.new(bar_index + 100, storedS2,    fmtPrice(storedS2),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.green,  style=label.style_label_left, size=size.small)
    s3PriceLbl    := label.new(bar_index + 100, storedS3,    fmtPrice(storedS3),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.green,  style=label.style_label_left, size=size.small)
    s4PriceLbl    := label.new(bar_index + 100, storedS4,    fmtPrice(storedS4),    xloc=xloc.bar_index, color=#ffffff00, textcolor=color.green,  style=label.style_label_left, size=size.small)

if not na(pivotLine) and show_pivots_eff
    line.set_xy2(pivotLine, bar_index + 100, storedPivot)
    line.set_xy2(bcLine,    bar_index + 100, storedBC)
    line.set_xy2(tcLine,    bar_index + 100, storedTC)
    line.set_xy2(r1Line,    bar_index + 100, storedR1)
    line.set_xy2(r2Line,    bar_index + 100, storedR2)
    line.set_xy2(r3Line,    bar_index + 100, storedR3)
    line.set_xy2(r4Line,    bar_index + 100, storedR4)
    line.set_xy2(s1Line,    bar_index + 100, storedS1)
    line.set_xy2(s2Line,    bar_index + 100, storedS2)
    line.set_xy2(s3Line,    bar_index + 100, storedS3)
    line.set_xy2(s4Line,    bar_index + 100, storedS4)
    if not na(cprMagneticLbl)
        label.set_xy(cprMagneticLbl, bar_index + 50, math.avg(storedTC, storedBC))
    if not na(pivotPriceLbl)
        label.set_x(pivotPriceLbl, bar_index + 100)
        label.set_x(bcPriceLbl,    bar_index + 100)
        label.set_x(tcPriceLbl,    bar_index + 100)
        label.set_x(r1PriceLbl,    bar_index + 100)
        label.set_x(r2PriceLbl,    bar_index + 100)
        label.set_x(r3PriceLbl,    bar_index + 100)
        label.set_x(r4PriceLbl,    bar_index + 100)
        label.set_x(s1PriceLbl,    bar_index + 100)
        label.set_x(s2PriceLbl,    bar_index + 100)
        label.set_x(s3PriceLbl,    bar_index + 100)
        label.set_x(s4PriceLbl,    bar_index + 100)

//----------------
// Trading Sessions — pick the markets you trade and the script highlights
// the active hours with a soft background tint. Lets traders see at a
// glance which session created which move.
//
// Times are bound to each market's home exchange timezone, so they stay
// correct regardless of the chart's symbol or the user's local TZ.
//----------------

// Sessions are Pro-tier+. Beginner tier stays minimal (Lifeline +
// Trap Alerts + Buy/Sell + candle colours + legend only).
show_session_india_in  = input.bool(true,  title="Highlight Indian (NSE)",   group="🕐 Trading Sessions")
show_session_asia_in   = input.bool(false, title="Highlight Asia (Tokyo)",   group="🕐 Trading Sessions")
show_session_london_in = input.bool(false, title="Highlight London",         group="🕐 Trading Sessions")
show_session_nyc_in    = input.bool(false, title="Highlight NYC",            group="🕐 Trading Sessions")

show_session_india  = (is_custom ? show_session_india_in  : is_pro_or_up) and show_session_india_in
show_session_asia   = (is_custom ? show_session_asia_in   : is_pro_or_up) and show_session_asia_in
show_session_london = (is_custom ? show_session_london_in : is_pro_or_up) and show_session_london_in
show_session_nyc    = (is_custom ? show_session_nyc_in    : is_pro_or_up) and show_session_nyc_in

// Session marker colours — used for the start/end vertical strips and
// for the top label text. Higher opacity than the old full-background
// highlight (no point being subtle on a single-bar mark).
// Saffron — recognisable Indian palette
sess_india_color  = input.color(color.new(#FF9933, 60), title="Indian Color",  group="🕐 Trading Sessions")
// Cyan — cool morning Tokyo
sess_asia_color   = input.color(color.new(#4DD0E1, 60), title="Asia Color",   group="🕐 Trading Sessions")
// Light yellow — London fog / dawn
sess_london_color = input.color(color.new(#FFEB3B, 60), title="London Color", group="🕐 Trading Sessions")
// Soft purple — Wall Street power
sess_nyc_color    = input.color(color.new(#B39DDB, 60), title="NYC Color",    group="🕐 Trading Sessions")

in_session_india  = not na(time(timeframe.period, "0915-1530:1234567", "Asia/Kolkata"))
in_session_asia   = not na(time(timeframe.period, "0900-1500:1234567", "Asia/Tokyo"))
in_session_london = not na(time(timeframe.period, "0800-1630:1234567", "Europe/London"))
in_session_nyc    = not na(time(timeframe.period, "0930-1600:1234567", "America/New_York"))

// Boundary detection — first bar inside session = start, first bar
// outside after being in session = end. Each fires once per session.
is_india_start  = show_session_india  and in_session_india  and not in_session_india[1]
is_india_end    = show_session_india  and in_session_india[1]  and not in_session_india
is_asia_start   = show_session_asia   and in_session_asia   and not in_session_asia[1]
is_asia_end     = show_session_asia   and in_session_asia[1]   and not in_session_asia
is_london_start = show_session_london and in_session_london and not in_session_london[1]
is_london_end   = show_session_london and in_session_london[1] and not in_session_london
is_nyc_start    = show_session_nyc    and in_session_nyc    and not in_session_nyc[1]
is_nyc_end      = show_session_nyc    and in_session_nyc[1]    and not in_session_nyc

// Vertical strips at session start + end. Single bar each = clean
// boundary marker without burying price.
bgcolor(is_india_start  or is_india_end  ? sess_india_color  : na, title="Indian Session Marker")
bgcolor(is_asia_start   or is_asia_end   ? sess_asia_color   : na, title="Asia Session Marker")
bgcolor(is_london_start or is_london_end ? sess_london_color : na, title="London Session Marker")
bgcolor(is_nyc_start    or is_nyc_end    ? sess_nyc_color    : na, title="NYC Session Marker")

// Session brackets — horizontal arrow line spanning start → end with
// the session name centered between the arrowheads. Created on session
// start, extended on each in-session bar so the bracket grows live as
// the session progresses. Pine v5's line.style_arrow_both gives true
// double-arrow rendering.
//
// Vertical placement: each session sits at a slightly different multiple
// above the session high so multiple enabled sessions don't overlap.

f_session_top(idx) =>
    high * (1.005 + 0.008 * idx)

// India bracket
var int   india_start_bar = na
var float india_top_y     = na
var line  india_bracket   = na
var label india_lbl       = na
if is_india_start
    india_start_bar := bar_index
    india_top_y     := f_session_top(0)
    if not na(india_bracket)
        line.delete(india_bracket)
    if not na(india_lbl)
        label.delete(india_lbl)
    india_bracket := line.new(bar_index, india_top_y, bar_index, india_top_y, color=#FF9933, width=2, style=line.style_arrow_both)
    india_lbl     := label.new(bar_index, india_top_y, "Indian Market", color=color.new(color.white, 0), textcolor=#FF9933, style=label.style_label_center, size=size.small)
if in_session_india and not na(india_bracket)
    new_top = math.max(india_top_y, f_session_top(0))
    line.set_xy1(india_bracket, india_start_bar, new_top)
    line.set_xy2(india_bracket, bar_index,       new_top)
    label.set_xy(india_lbl, int((india_start_bar + bar_index) / 2), new_top)
    india_top_y := new_top

// Asia bracket
var int   asia_start_bar = na
var float asia_top_y     = na
var line  asia_bracket   = na
var label asia_lbl       = na
if is_asia_start
    asia_start_bar := bar_index
    asia_top_y     := f_session_top(1)
    if not na(asia_bracket)
        line.delete(asia_bracket)
    if not na(asia_lbl)
        label.delete(asia_lbl)
    asia_bracket := line.new(bar_index, asia_top_y, bar_index, asia_top_y, color=#0FA9C9, width=2, style=line.style_arrow_both)
    asia_lbl     := label.new(bar_index, asia_top_y, "Asia (Tokyo)", color=color.new(color.white, 0), textcolor=#0FA9C9, style=label.style_label_center, size=size.small)
if in_session_asia and not na(asia_bracket)
    new_top_a = math.max(asia_top_y, f_session_top(1))
    line.set_xy1(asia_bracket, asia_start_bar, new_top_a)
    line.set_xy2(asia_bracket, bar_index,      new_top_a)
    label.set_xy(asia_lbl, int((asia_start_bar + bar_index) / 2), new_top_a)
    asia_top_y := new_top_a

// London bracket
var int   london_start_bar = na
var float london_top_y     = na
var line  london_bracket   = na
var label london_lbl       = na
if is_london_start
    london_start_bar := bar_index
    london_top_y     := f_session_top(2)
    if not na(london_bracket)
        line.delete(london_bracket)
    if not na(london_lbl)
        label.delete(london_lbl)
    london_bracket := line.new(bar_index, london_top_y, bar_index, london_top_y, color=#C49000, width=2, style=line.style_arrow_both)
    london_lbl     := label.new(bar_index, london_top_y, "London", color=color.new(color.white, 0), textcolor=#C49000, style=label.style_label_center, size=size.small)
if in_session_london and not na(london_bracket)
    new_top_l = math.max(london_top_y, f_session_top(2))
    line.set_xy1(london_bracket, london_start_bar, new_top_l)
    line.set_xy2(london_bracket, bar_index,        new_top_l)
    label.set_xy(london_lbl, int((london_start_bar + bar_index) / 2), new_top_l)
    london_top_y := new_top_l

// NYC bracket
var int   nyc_start_bar = na
var float nyc_top_y     = na
var line  nyc_bracket   = na
var label nyc_lbl       = na
if is_nyc_start
    nyc_start_bar := bar_index
    nyc_top_y     := f_session_top(3)
    if not na(nyc_bracket)
        line.delete(nyc_bracket)
    if not na(nyc_lbl)
        label.delete(nyc_lbl)
    nyc_bracket := line.new(bar_index, nyc_top_y, bar_index, nyc_top_y, color=#7D5BB7, width=2, style=line.style_arrow_both)
    nyc_lbl     := label.new(bar_index, nyc_top_y, "NYC", color=color.new(color.white, 0), textcolor=#7D5BB7, style=label.style_label_center, size=size.small)
if in_session_nyc and not na(nyc_bracket)
    new_top_n = math.max(nyc_top_y, f_session_top(3))
    line.set_xy1(nyc_bracket, nyc_start_bar, new_top_n)
    line.set_xy2(nyc_bracket, bar_index,     new_top_n)
    label.set_xy(nyc_lbl, int((nyc_start_bar + bar_index) / 2), new_top_n)
    nyc_top_y := new_top_n

//----------------
// 100% Buyers / Sellers Marubozu detection
// (colour applied below in the unified barcolor() resolver)
//----------------

C_Len = 14
C_ShadowPercent = 5.0
C_BodyHi = math.max(close, open)
C_BodyLo = math.min(close, open)
C_Body = C_BodyHi - C_BodyLo
C_BodyAvg = ta.ema(C_Body, C_Len)
C_LongBody = C_Body > C_BodyAvg
C_UpShadow = high - C_BodyHi
C_DnShadow = C_BodyLo - low
C_WhiteBody = open < close
C_BlackBody = open > close
C_MarubozuWhiteBullish = C_WhiteBody and C_LongBody and C_UpShadow <= C_ShadowPercent / 100 * C_Body and C_DnShadow <= C_ShadowPercent / 100 * C_Body
C_MarubozuBlackBearish = C_BlackBody and C_LongBody and C_UpShadow <= C_ShadowPercent / 100 * C_Body and C_DnShadow <= C_ShadowPercent / 100 * C_Body

//----------------
// Momentum Candles
// (colour applied below in the unified barcolor() resolver)
//----------------

// Blue / Black momentum + Marubozu candle colours — Beginner-tier+. The
// candle-colour legend (legend table) explains what each colour means;
// gating this to Beginner+ keeps the simplest tier visually meaningful.
show_momentum  = input.bool(true, title="Show Momentum Candles *", group="🎨 Candles & Trends")
show_momentum_eff = is_custom ? show_momentum : is_beginner_or_up
BODY_THRESHOLD = 0.70

body_size  = math.abs(close - open)
true_range = math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))

is_bullish_momentum = body_size / true_range >= BODY_THRESHOLD and close > open
is_bearish_momentum = body_size / true_range >= BODY_THRESHOLD and close < open

//----------------
// Volume Divergence (Yellow Careful Candle)
// Pulls intra-bar up/down volume from a lower timeframe and flags bars
// where the candle body direction contradicts the dominant volume —
// e.g. a red candle that printed despite stronger up-volume at the
// micro level. Signals a potential trap / reversal context.
//----------------

show_yellow_candle = input.bool(true, title="Show Trap Alerts (Yellow Candle) *", group="🎨 Candles & Trends")
show_yellow_eff    = is_custom ? show_yellow_candle : is_beginner_or_up

var bool RedCandle   = false
var bool GreenCandle = false

barRangeBody = open - close
if barRangeBody < 0
    RedCandle := true
else
    GreenCandle := true

upAndDownVolume() =>
    posVol = 0.0
    negVol = 0.0
    switch
        close >  open     => posVol += volume
        close <  open     => negVol -= volume
        close >= close[1] => posVol += volume
        close <  close[1] => negVol -= volume
    [posVol, negVol]

lowerTimeframe = switch
    timeframe.isintraday => "1"
    timeframe.isdaily    => "5"
    => "60"

[upVolumeArray, downVolumeArray] = request.security_lower_tf(syminfo.tickerid, lowerTimeframe, upAndDownVolume())
upVolume   = array.sum(upVolumeArray)
downVolume = array.sum(downVolumeArray)

ectopicBar = (RedCandle   and math.abs(upVolume   * 1.5) < math.abs(downVolume)) or
             (GreenCandle and math.abs(downVolume * 1.5) < math.abs(upVolume))

plotshape(show_yellow_eff and ectopicBar, title='Trap Alert', style=shape.flag, text='!', color=color.new(#FFC107, 0), textcolor=color.new(color.black, 0), location=location.abovebar)
alertcondition(ectopicBar, title="Volume Divergence", message="Watch the Market — yellow careful candle")

RedCandle   := false
GreenCandle := false

//----------------
// Unified barcolor() resolver — single call, explicit precedence
//   1. Yellow Careful Candle (volume divergence) — strongest signal, wins
//   2. Bullish / bearish momentum
//   3. Marubozu fills the gap when momentum doesn't fire
//   4. Otherwise no recolour
//
// Bull / bear shades softened from pure blue / black so the chart reads
// less harshly against TradingView's default backdrop.
//----------------

// Psychology-tuned palette:
//   BULL_BAR — light periwinkle blue, calm + trustworthy (not loud)
//   BEAR_BAR — very dark gray, serious not panicked
//   WARN_BAR — amber-gold, reads as "premium warning" instead of the
//              candy-yellow that screams cheap-alert
BULL_BAR = #5e7eff
BEAR_BAR = #2c2c2c
WARN_BAR = #FFC107

var color final_bar_color = na
final_bar_color := show_yellow_eff and ectopicBar    ? WARN_BAR
                 : show_momentum_eff and is_bullish_momentum ? BULL_BAR
                 : show_momentum_eff and is_bearish_momentum ? BEAR_BAR
                 : C_MarubozuWhiteBullish                ? BULL_BAR
                 : C_MarubozuBlackBearish                ? BEAR_BAR
                 : na
barcolor(final_bar_color, title="Candle coloring")

//----------------
// Trend Line Break with Buy/Sell Signals
//----------------

length     = 14
mult       = 1.0
calcMethod = 'Atr'
backpaint  = true

// Trend break up/down — semantic green/red aligned with rest of script
// (#00897b teal + #ff5252 coral were aesthetically nice but broke the
// "green = buy / red = sell" mental model the rest of the chart uses).
upCss = color.new(#22A06B, 0)
dnCss = color.new(#D94545, 0)
showTrend = input(false, 'Show Buy/Sell Signals (trend break)', group="🎨 Candles & Trends")
showTrend_eff = is_custom ? showTrend : is_beginner_or_up
showExt   = true

var upper    = 0.
var lower    = 0.
var slope_ph = 0.
var slope_pl = 0.
var offset   = backpaint ? length : 0

n = bar_index
src := close

ph = ta.pivothigh(length, length)
pl = ta.pivotlow(length,  length)

slope = switch calcMethod
    'Atr'    => ta.atr(length) / length * mult
    'Stdev'  => ta.stdev(src, length) / length * mult
    'Linreg' => math.abs(ta.sma(src * n, length) - ta.sma(src, length) * ta.sma(n, length)) / ta.variance(n, length) / 2 * mult

slope_ph := ph ? slope : slope_ph
slope_pl := pl ? slope : slope_pl

upper := ph ? ph : upper - slope_ph
lower := pl ? pl : lower + slope_pl

var upos = 0
var dnos = 0
upos := ph ? 0 : close > upper - slope_ph * length ? 1 : upos
dnos := pl ? 0 : close < lower + slope_pl * length ? 1 : dnos

// Trend lines themselves were too noisy on the chart — kept only the B / S
// signal labels. Detection logic still runs (uses upper/lower internally),
// just the diagonal trend-line plots are gone.
plotshape(showTrend_eff and upos > upos[1] ? low  : na, "Buy Signal",  shape.labelup,   location.absolute, upCss, text="B", textcolor=color.white, size=size.tiny)
plotshape(showTrend_eff and dnos > dnos[1] ? high : na, "Sell Signal", shape.labeldown, location.absolute, dnCss, text="S", textcolor=color.white, size=size.tiny)

alertcondition(upos > upos[1], 'Upward Breakout',   'Price broke the down-trendline upward')
alertcondition(dnos > dnos[1], 'Downward Breakout', 'Price broke the up-trendline downward')

//----------------
// Highs & Lows MTF — Daily / Weekly / Monthly previous extremes
//----------------

// MTF previous high/low lines — gated to Pro+ tier so Beginner stays
// minimal. Custom mode: per-timeframe toggles take effect directly.
show_pdhl_in = input(true,    'Daily',   inline='daily',   group='📅 Higher Timeframe Levels')
pdhl_style   = input.string('----', '',  inline='daily',   group='📅 Higher Timeframe Levels', options=['⎯⎯⎯','----','····'])
pdhl_css     = input(#2157f3, '',        inline='daily',   group='📅 Higher Timeframe Levels')

show_pwhl_in = input(true,    'Weekly',  inline='weekly',  group='📅 Higher Timeframe Levels')
pwhl_style   = input.string('----', '',  inline='weekly',  group='📅 Higher Timeframe Levels', options=['⎯⎯⎯','----','····'])
pwhl_css     = input(#2157f3, '',        inline='weekly',  group='📅 Higher Timeframe Levels')

show_pmhl_in = input(true,    'Monthly', inline='monthly', group='📅 Higher Timeframe Levels')
pmhl_style   = input.string('----', '',  inline='monthly', group='📅 Higher Timeframe Levels', options=['⎯⎯⎯','----','····'])
pmhl_css     = input(#2157f3, '',        inline='monthly', group='📅 Higher Timeframe Levels')

show_pdhl = (is_custom ? show_pdhl_in : is_pro_or_up) and show_pdhl_in
show_pwhl = (is_custom ? show_pwhl_in : is_pro_or_up) and show_pwhl_in
show_pmhl = (is_custom ? show_pmhl_in : is_pro_or_up) and show_pmhl_in

color TRANSP_CSS = #ffffff00

get_line_style_mtf(s) =>
    out_s = switch s
        '⎯⎯⎯'  => line.style_solid
        '----' => line.style_dashed
        '····' => line.style_dotted
    out_s

hl() => [high, low]

phl(h, l, tf, css, sty) =>
    var line  high_line = line.new(na, na, na, na, xloc=xloc.bar_time, color=css, style=get_line_style_mtf(sty))
    var label high_lbl  = label.new(na, na, xloc=xloc.bar_time, text=str.format('P{0}H', tf), color=TRANSP_CSS, textcolor=css, size=size.small, style=label.style_label_left)
    var line  low_line  = line.new(na, na, na, na, xloc=xloc.bar_time, color=css, style=get_line_style_mtf(sty))
    var label low_lbl   = label.new(na, na, xloc=xloc.bar_time, text=str.format('P{0}L', tf), color=TRANSP_CSS, textcolor=css, size=size.small, style=label.style_label_left)
    hy = ta.valuewhen(h != h[1], h, 1)
    hx = ta.valuewhen(h == high, time, 1)
    ly = ta.valuewhen(l != l[1], l, 1)
    lx = ta.valuewhen(l == low,  time, 1)
    if barstate.islast
        ext = time + (time - time[1]) * 20
        line.set_xy1(high_line, hx, hy)
        line.set_xy2(high_line, ext, hy)
        label.set_xy(high_lbl, ext, hy)
        line.set_xy1(low_line, lx, ly)
        line.set_xy2(low_line, ext, ly)
        label.set_xy(low_lbl, ext, ly)

[pdh, pdl] = request.security(syminfo.tickerid, 'D', hl(), lookahead=barmerge.lookahead_on)
[pwh, pwl] = request.security(syminfo.tickerid, 'W', hl(), lookahead=barmerge.lookahead_on)
[pmh, pml] = request.security(syminfo.tickerid, 'M', hl(), lookahead=barmerge.lookahead_on)

if show_pdhl
    phl(pdh, pdl, 'D', pdhl_css, pdhl_style)
if show_pwhl
    phl(pwh, pwl, 'W', pwhl_css, pwhl_style)
if show_pmhl
    phl(pmh, pml, 'M', pmhl_css, pmhl_style)

//----------------
// Big Buyer / Big Seller Zones (Grandpa Automated Supply / Demand)
//----------------

show_grandpa = input.bool(true, title="Show Big Buyer / Big Seller Zones *", group="🎨 Candles & Trends")
show_grandpa_eff = is_custom ? show_grandpa : is_pro_or_up

swing_length              = 8
history_of_demand_to_keep = 20
box_width                 = 6.0

show_price_action_labels = true
supply_color         = #FFB1B4
supply_outline_color = #ffffff
demand_color         = #A6D7A7
demand_outline_color = #ffffff
poi_label_color      = #363a45
// HH / LH / HL / LL swing labels float over chart bg — must adapt to
// theme or they disappear on dark mode.
swing_type_color     = auto_theme_colors ? chart.fg_color : #363a45

f_array_add_pop(arr, new_value_to_add) =>
    array.unshift(arr, new_value_to_add)
    array.pop(arr)

f_sh_sl_labels(arr, swing_type) =>
    var string label_text = na
    if swing_type == 1
        if array.get(arr, 0) >= array.get(arr, 1)
            label_text := 'HH'
        else
            label_text := 'LH'
        label.new(bar_index - swing_length, array.get(arr, 0), text=label_text, style=label.style_label_down, textcolor=swing_type_color, color=color.new(swing_type_color, 100), size=size.small)
    else if swing_type == -1
        if array.get(arr, 0) >= array.get(arr, 1)
            label_text := 'HL'
        else
            label_text := 'LL'
        label.new(bar_index - swing_length, array.get(arr, 0), text=label_text, style=label.style_label_up, textcolor=swing_type_color, color=color.new(swing_type_color, 100), size=size.small)

f_check_overlapping(new_poi, box_array, atr_local) =>
    atr_threshold = atr_local * 2
    okay_to_draw = true
    for i = 0 to array.size(box_array) - 1
        top_b = box.get_top(array.get(box_array, i))
        bottom_b = box.get_bottom(array.get(box_array, i))
        poi = (top_b + bottom_b) / 2
        upper_boundary = poi + atr_threshold
        lower_boundary = poi - atr_threshold
        if new_poi >= lower_boundary and new_poi <= upper_boundary
            okay_to_draw := false
            break
        else
            okay_to_draw := true
    okay_to_draw

f_supply_demand(value_array, bn_array, box_array, label_array, box_type, atr_local) =>
    atr_buffer = atr_local * (box_width / 10)
    box_left  = array.get(bn_array, 0)
    box_right = bar_index
    var float box_top    = 0.00
    var float box_bottom = 0.00
    var float poi        = 0.00
    if box_type == 1
        box_top    := array.get(value_array, 0)
        box_bottom := box_top - atr_buffer
        poi        := (box_top + box_bottom) / 2
    else if box_type == -1
        box_bottom := array.get(value_array, 0)
        box_top    := box_bottom + atr_buffer
        poi        := (box_top + box_bottom) / 2
    okay_to_draw = f_check_overlapping(poi, box_array, atr_local)
    if box_type == 1 and okay_to_draw
        box.delete(array.get(box_array, array.size(box_array) - 1))
        f_array_add_pop(box_array, box.new(left=box_left, top=box_top, right=box_right, bottom=box_bottom, border_color=supply_outline_color, bgcolor=supply_color, extend=extend.right, text='Big Seller Zone ', text_halign=text.align_center, text_valign=text.align_center, text_color=color.rgb(17, 18, 19), text_size=size.normal, xloc=xloc.bar_index))
        box.delete(array.get(label_array, array.size(label_array) - 1))
        f_array_add_pop(label_array, box.new(left=box_left, top=poi, right=box_right, bottom=poi, border_color=color.new(#0f0f0f, 79), bgcolor=color.new(poi_label_color, 90), extend=extend.right, text='Resistance', text_halign=text.align_left, text_valign=text.align_bottom, text_color=color.rgb(11, 68, 224), text_size=size.normal, xloc=xloc.bar_index))
    else if box_type == -1 and okay_to_draw
        box.delete(array.get(box_array, array.size(box_array) - 1))
        f_array_add_pop(box_array, box.new(left=box_left, top=box_top, right=box_right, bottom=box_bottom, border_color=demand_outline_color, bgcolor=demand_color, extend=extend.right, text='Big Buyer Zone', text_halign=text.align_center, text_valign=text.align_top, text_color=color.rgb(17, 18, 19), text_size=size.normal, xloc=xloc.bar_index))
        box.delete(array.get(label_array, array.size(label_array) - 1))
        f_array_add_pop(label_array, box.new(left=box_left, top=poi, right=box_right, bottom=poi, border_color=color.new(#0f0f0f, 79), bgcolor=color.new(poi_label_color, 90), extend=extend.right, text='Support', text_halign=text.align_left, text_valign=text.align_top, text_color=color.rgb(11, 68, 224), text_size=size.normal, xloc=xloc.bar_index))

f_sd_to_bos(box_array, bos_array, label_array, zone_type) =>
    if zone_type == 1
        for i = 0 to array.size(box_array) - 1
            level_to_break = box.get_top(array.get(box_array, i))
            if close >= level_to_break
                copied_box = box.copy(array.get(box_array, i))
                f_array_add_pop(bos_array, copied_box)
                mid = (box.get_top(array.get(box_array, i)) + box.get_bottom(array.get(box_array, i))) / 2
                box.set_top(array.get(bos_array, 0), mid)
                box.set_bottom(array.get(bos_array, 0), mid)
                box.set_extend(array.get(bos_array, 0), extend.none)
                box.set_right(array.get(bos_array, 0), bar_index)
                box.set_text_color(array.get(bos_array, 0), #10e817)
                box.set_text_size(array.get(bos_array, 0), size.small)
                box.set_text(array.get(bos_array, 0), '')
                box.delete(array.get(box_array, i))
                box.delete(array.get(label_array, i))
    if zone_type == -1
        for i = 0 to array.size(box_array) - 1
            level_to_break = box.get_bottom(array.get(box_array, i))
            if close <= level_to_break
                copied_box = box.copy(array.get(box_array, i))
                f_array_add_pop(bos_array, copied_box)
                mid = (box.get_top(array.get(box_array, i)) + box.get_bottom(array.get(box_array, i))) / 2
                box.set_top(array.get(bos_array, 0), mid)
                box.set_bottom(array.get(bos_array, 0), mid)
                box.set_extend(array.get(bos_array, 0), extend.none)
                box.set_right(array.get(bos_array, 0), bar_index)
                box.set_text_color(array.get(bos_array, 0), color.rgb(228, 15, 26, 6))
                box.set_text_size(array.get(bos_array, 0), size.small)
                box.set_text(array.get(bos_array, 0), '')
                box.set_text_halign(array.get(bos_array, 0), text.align_center)
                box.set_text_valign(array.get(bos_array, 0), text.align_center)
                box.delete(array.get(box_array, i))
                box.delete(array.get(label_array, i))

f_extend_box_endpoint(box_array) =>
    for i = 0 to array.size(box_array) - 1
        box.set_right(array.get(box_array, i), bar_index + 100)

atr_grandpa = ta.atr(50)

swing_high = ta.pivothigh(high, swing_length, swing_length)
swing_low  = ta.pivotlow(low,   swing_length, swing_length)

var swing_high_values = array.new_float(5, 0.00)
var swing_low_values  = array.new_float(5, 0.00)
var swing_high_bns    = array.new_int(5, 0)
var swing_low_bns     = array.new_int(5, 0)

var current_supply_box = array.new_box(history_of_demand_to_keep, na)
var current_demand_box = array.new_box(history_of_demand_to_keep, na)
var current_supply_poi = array.new_box(history_of_demand_to_keep, na)
var current_demand_poi = array.new_box(history_of_demand_to_keep, na)

var supply_bos = array.new_box(5, na)
var demand_bos = array.new_box(5, na)

if show_grandpa_eff
    if not na(swing_high)
        f_array_add_pop(swing_high_values, swing_high)
        f_array_add_pop(swing_high_bns, bar_index[swing_length])
        if show_price_action_labels
            f_sh_sl_labels(swing_high_values, 1)
        f_supply_demand(swing_high_values, swing_high_bns, current_supply_box, current_supply_poi, 1, atr_grandpa)
    else if not na(swing_low)
        f_array_add_pop(swing_low_values, swing_low)
        f_array_add_pop(swing_low_bns, bar_index[swing_length])
        if show_price_action_labels
            f_sh_sl_labels(swing_low_values, -1)
        f_supply_demand(swing_low_values, swing_low_bns, current_demand_box, current_demand_poi, -1, atr_grandpa)

    f_sd_to_bos(current_supply_box, supply_bos, current_supply_poi,  1)
    f_sd_to_bos(current_demand_box, demand_bos, current_demand_poi, -1)

    f_extend_box_endpoint(current_supply_box)
    f_extend_box_endpoint(current_demand_box)

//----------------
// Candle Color Legend — fixed bottom-right box explaining bar colours
// Tables stay pinned regardless of price / zoom. Populated only on the
// last bar so it doesn't burn historical-bar compute. Toggle hides via
// table.clear so cells don't linger when show_legend flips off.
//----------------

// 5-row table: brand strip + Candle Guide header + 3 colour rows.
// Brand strip uses the project palette (navy panel + cyan accent +
// white text) — quietly visible without competing with price action.
var table legend = table.new(position.bottom_right, 2, 5,
   bgcolor=color.new(color.gray, 75),
   border_color=color.gray,
   border_width=1)

if barstate.islast
    if show_legend
        // Row 0 — brand strip (subtle, navy bg, cyan star + white text)
        table.cell(legend, 0, 0, "★",                          bgcolor=#0E1530, text_color=#22D3EE, text_size=size.small)
        table.cell(legend, 1, 0, " EasyTradeSetup · Golden v5", bgcolor=#0E1530, text_color=color.white, text_size=size.small)
        // Row 1 — section header
        table.cell(legend, 0, 1, "",                            bgcolor=color.new(color.gray, 30))
        table.cell(legend, 1, 1, "Candle Guide",                bgcolor=color.new(color.gray, 30), text_color=color.white, text_size=size.normal)
        // Rows 2-4 — colour swatches + meanings
        table.cell(legend, 0, 2, "    ",                        bgcolor=#5e7eff)
        table.cell(legend, 1, 2, " Aggressive Buying ",         text_color=chart.fg_color, text_size=size.small)
        table.cell(legend, 0, 3, "    ",                        bgcolor=#2c2c2c)
        table.cell(legend, 1, 3, " Aggressive Selling ",        text_color=chart.fg_color, text_size=size.small)
        table.cell(legend, 0, 4, "    ",                        bgcolor=#FFC107)
        table.cell(legend, 1, 4, " Careful — tighten SL ",      text_color=chart.fg_color, text_size=size.small)
    else
        table.clear(legend, 0, 0, 1, 4)

// =============================================================================
// END OF v5 SCRIPT
// =============================================================================
