# VoiceDesk AI — example environment file
# Copy to `.env` and adjust values as needed.

# SQLite database path (relative to backend/ working dir)
DATABASE_URL=sqlite:///./voicedesk.db

# App metadata
APP_NAME=VoiceDesk AI
APP_ENV=local

# LLM provider (placeholder — currently unused, mock service is hardcoded)
LLM_PROVIDER=mock
LLM_API_KEY=
