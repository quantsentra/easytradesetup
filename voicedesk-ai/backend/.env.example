# VoiceDesk AI — example environment file
# Copy to `.env` and adjust values.

# ----- Database --------------------------------------------------------------
# SQLite path is relative to the backend/ working dir.
DATABASE_URL=sqlite:///./voicedesk.db

# ----- App metadata ----------------------------------------------------------
APP_NAME=VoiceDesk AI
APP_ENV=local

# ----- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO

# ----- LLM provider ----------------------------------------------------------
# Choose one of: mock | openai | anthropic
#   mock      → no network, deterministic keyword extractor (default)
#   openai    → uses gpt-4o-mini by default; set LLM_MODEL to override
#   anthropic → uses claude-haiku-4-5-20251001 by default; set LLM_MODEL to override
LLM_PROVIDER=mock

# Generic API key consumed by whichever provider is selected above.
# Leave blank for mock. For openai/anthropic, set this OR the provider's
# native env var (OPENAI_API_KEY / ANTHROPIC_API_KEY) — either works.
LLM_API_KEY=

# Optional. Examples:
#   LLM_MODEL=gpt-4o-mini
#   LLM_MODEL=gpt-4o
#   LLM_MODEL=claude-haiku-4-5-20251001
#   LLM_MODEL=claude-sonnet-4-6
LLM_MODEL=

# ----- External ticket provider ---------------------------------------------
# Local SQLite is ALWAYS written (source of truth). This only controls
# whether a ticket is also forwarded to an external helpdesk.
#
# Choose one of: local | freshdesk
TICKET_PROVIDER=local

# Freshdesk credentials — only required when TICKET_PROVIDER=freshdesk.
# FRESHDESK_DOMAIN is the subdomain only, e.g. for `acme.freshdesk.com` use `acme`.
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

